<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" 
         xmlns="http://xmlns.jcp.org/xml/ns/javaee" 
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">
    
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>
    
    <servlet>
        <servlet-name>CampusController</servlet-name>
        <servlet-class>com.controller.CampusController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ComplaintController</servlet-name>
        <servlet-class>com.controller.ComplaintController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CampusController</servlet-name>
        <url-pattern>/CampusController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ComplaintController</servlet-name>
        <url-pattern>/ComplaintController</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
